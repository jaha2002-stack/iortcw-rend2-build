diff -Naur a/MP/code/rend2/glsl/dlight_fp.glsl b/MP/code/rend2/glsl/dlight_fp.glsl
--- a/MP/code/rend2/glsl/dlight_fp.glsl	2026-07-08 18:19:52.295336885 +0000
+++ b/MP/code/rend2/glsl/dlight_fp.glsl	2026-07-08 18:19:52.301151184 +0000
@@ -1 +1,68 @@
-uniform sampler2D u_DiffuseMap; uniform int u_AlphaTest; varying vec2 var_Tex1; varying vec4 var_Color; void main() { vec4 color = texture2D(u_DiffuseMap, var_Tex1); float alpha = color.a * var_Color.a; if (u_AlphaTest == 1) { if (alpha == 0.0) discard; } else if (u_AlphaTest == 2) { if (alpha >= 0.5) discard; } else if (u_AlphaTest == 3) { if (alpha < 0.5) discard; } gl_FragColor.rgb = color.rgb * var_Color.rgb; gl_FragColor.a = alpha; }
+uniform sampler2D u_DiffuseMap;
+uniform int u_AlphaTest;
+uniform vec4 u_DlightInfo;
+
+varying vec2 var_Tex1;
+varying vec4 var_Color;
+varying vec3 var_DlightVector;
+varying vec3 var_SurfaceNormal;
+
+void main()
+{
+	// Prevent projected light wrap/leak outside the dlight cookie.
+	if (var_Tex1.x <= 0.0 || var_Tex1.x >= 1.0 || var_Tex1.y <= 0.0 || var_Tex1.y >= 1.0)
+	{
+		discard;
+	}
+
+	vec4 color = texture2D(u_DiffuseMap, var_Tex1);
+	float alpha = color.a * var_Color.a;
+
+	if (u_AlphaTest == 1)
+	{
+		if (alpha <= 0.0)
+		{
+			discard;
+		}
+	}
+	else if (u_AlphaTest == 2)
+	{
+		if (alpha >= 0.5)
+		{
+			discard;
+		}
+	}
+	else if (u_AlphaTest == 3)
+	{
+		if (alpha < 0.5)
+		{
+			discard;
+		}
+	}
+
+	vec3 Lvec = var_DlightVector;
+	float distanceToLight = length(Lvec);
+	vec3 L = Lvec / max(distanceToLight, 0.0001);
+	vec3 N = normalize(var_SurfaceNormal);
+
+	// Smooth Lambert-like facing term.  This replaces the original hard step()
+	// and makes dlights much less harsh on corners and low-poly surfaces.
+	float facing = max(dot(N, L), 0.0);
+	facing = smoothstep(0.02, 0.35, facing);
+
+	// Real radial attenuation based on the dlight radius scale.
+	// u_DlightInfo.a is the existing inverse radius/projection scale.
+	float radial = clamp(1.0 - distanceToLight * u_DlightInfo.a, 0.0, 1.0);
+	radial = radial * radial * (3.0 - 2.0 * radial);
+
+	// Preserve the stock axial fade as an extra guard so old dlight projection
+	// behavior remains stable, but make the visible response smoother overall.
+	float axial = clamp(2.0 * (1.0 - abs(Lvec.z) * u_DlightInfo.a), 0.0, 1.0);
+	axial = smoothstep(0.0, 1.0, axial);
+
+	float dlightmod = facing * radial * axial;
+
+	vec3 litColor = color.rgb * var_Color.rgb * dlightmod;
+	gl_FragColor.rgb = clamp(litColor, 0.0, 1.0);
+	gl_FragColor.a = alpha;
+}
diff -Naur a/MP/code/rend2/glsl/dlight_vp.glsl b/MP/code/rend2/glsl/dlight_vp.glsl
